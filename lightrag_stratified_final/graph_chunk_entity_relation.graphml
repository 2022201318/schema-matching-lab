    <node id="Number Of Lymph Nodes Positive For Tumor">
      <data key="d0">Number Of Lymph Nodes Positive For Tumor</data>
      <data key="d1">data</data>
      <data key="d2">Number Of Lymph Nodes Positive For Tumor records the number of lymph nodes with confirmed tumor cells.&lt;SEP&gt;Number Of Lymph Nodes Positive For Tumor is a field in Table Cao, reporting the quantity of lymph nodes found to contain tumor cells.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-5b74bb3e12c83406f44983363ccf9e2f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1772772550</data>
