    <node id="RNAseq R1 Filename">
      <data key="d0">RNAseq R1 Filename</data>
      <data key="d1">data</data>
      <data key="d2">RNAseq R1 Filename lists the filenames associated with the first read of RNA sequencing data for biological samples.&lt;SEP&gt;RNAseq R1 Filename refers to the set of FASTQ file names for the first-read RNA sequencing tumor samples.&lt;SEP&gt;RNAseq R1 Filename is a field in Dou representing the filename for RNA sequencing read 1 files.&lt;SEP&gt;RNAseq R1 Filename is a field in Table Dou representing filenames for RNA sequencing read 1, with sample values such as '0072_AHK3GVBBXX_TAGCTT_S17_L005_R1_001.fastq.gz'.</data>
