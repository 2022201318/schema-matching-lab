    <node id="Neoplastic Cellularity">
      <data key="d0">Neoplastic Cellularity</data>
      <data key="d1">data</data>
      <data key="d2">Neoplastic Cellularity records the proportion of neoplastic cells in samples.&lt;SEP&gt;Neoplastic Cellularity records numeric values for neoplastic cell fractions in tissue samples, as seen in Table Cao from source9.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-f35709cd063c7f945768e5ca53cbe7fe</data>
