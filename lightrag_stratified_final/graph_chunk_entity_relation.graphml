      <data key="d6" />
    </node>
    <node id="Medical Condition">
      <data key="d0">Medical Condition</data>
      <data key="d1">data</data>
      <data key="d2">Medical Condition documents co-existing medical disorders for each participant.&lt;SEP&gt;Medical Condition contains patient diagnoses and procedures, including diseases such as hypertension, diabetes mellitus type II, and surgical histories, as listed in Table Cao from source9.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-f35709cd063c7f945768e5ca53cbe7fe</data>
      <data key="d4">unknown_source</data>
