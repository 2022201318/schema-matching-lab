    <node id="Study">
      <data key="d0">Study</data>
      <data key="d1">concept</data>
      <data key="d2">Study refers to the central research effort analyzing clinical and pathologic features of participants with pancreatic pathologies.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd</data>
