      <data key="d0">Normal Included For The Study</data>
      <data key="d1">concept</data>
      <data key="d2">Normal Included For The Study indicates whether normal samples were considered for inclusion in the study.&lt;SEP&gt;Normal Included For The Study is a field in the Cao table indicating if a normal sample was included in the study, with sample value 'yes'.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-4cdc7d5a512e452fb24328ea78eddeff</data>
      <data key="d4">unknown_source</data>
