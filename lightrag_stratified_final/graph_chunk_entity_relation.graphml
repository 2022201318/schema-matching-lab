    <node id="Participant Country">
      <data key="d0">Participant Country</data>
      <data key="d1">concept</data>
      <data key="d2">Participant Country records the country of origin or residence of participants, with samples from United States, Canada, and Other.&lt;SEP&gt;Participant Country is a field in the Cao table recording the country of the participant, with sample values like United States, Canada, and Other.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-4cdc7d5a512e452fb24328ea78eddeff</data>
