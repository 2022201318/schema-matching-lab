    <node id="Residual Tumor">
      <data key="d0">Residual Tumor</data>
      <data key="d1">concept</data>
      <data key="d2">Residual Tumor records whether any residual tumor was identified post-surgery, categorized as R0, R1, or R2.&lt;SEP&gt;Residual Tumor is a pathological descriptor in Table Cao, classifying the amount of remaining tumor after surgery, such as none, microscopic, or macroscopic residual tumor.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-5b74bb3e12c83406f44983363ccf9e2f</data>
