    <node id="Histology Diagnosis">
      <data key="d0">Histology Diagnosis</data>
      <data key="d1">concept</data>
      <data key="d2">Histology Diagnosis identifies the pathological classification of tissue, with PDAC as a prominent diagnosis among samples.&lt;SEP&gt;Histology Diagnosis is a field in the Cao table with the value 'PDAC', referring to the pathological diagnosis of the tumor.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-4cdc7d5a512e452fb24328ea78eddeff</data>
      <data key="d4">unknown_source</data>
