    <node id="Bmi">
      <data key="d0">Bmi</data>
      <data key="d1">data</data>
      <data key="d2">Bmi records the body mass index of participants.&lt;SEP&gt;Bmi is a field in Table Cao representing the body mass index value recorded for a patient.</data>
      <data key="d3">chunk-07e1af1bf39bca6afef0e83065e9d6cd&lt;SEP&gt;chunk-5b74bb3e12c83406f44983363ccf9e2f</data>
      <data key="d4">unknown_source</data>
