    <node id="source15.McDermott">
      <data key="d0">source15.McDermott</data>
      <data key="d1">TABLE</data>
      <data key="d2">The McDermott.csv table contains patient data for ovarian cancer cases, including identifiers, demographic information, tumor characteristics, and medical history. It features columns for CPTAC Case ID, tumor and normal tissue analyzed, age, gender, race, ethnicity, disease site, histological subtype, and various medical history indicators, with data types primarily string and float.</data>
      <data key="d3">UNKNOWN</data>
      <data key="d4">custom_kg</data>
      <data key="d5">1773650711</data>
