    <node id="Project_Registry.csv">
      <data key="d0">Project_Registry.csv</data>
      <data key="d1">data</data>
      <data key="d2">Project_Registry.csv is a data table containing comprehensive information about various projects, including fiscal year, programming process, status, organization classification and type, sector and continent, project spending, thematic indicators, and unique identifiers for projects, sections, and branches.</data>
      <data key="d3">chunk-f1429fda71864e79d20fd0eb1fba290c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1773646038</data>
      <data key="d6" />
    </node>
    <node id="Fiscal Year">
      <data key="d0">Fiscal Year</data>
      <data key="d1">concept</data>
      <data key="d2">Fiscal Year refers to the fiscal period during which a project was active.</data>
      <data key="d3">chunk-f1429fda71864e79d20fd0eb1fba290c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1773646038</data>
      <data key="d6" />
    </node>
    <node id="Programming Process">
      <data key="d0">Programming Process</data>
      <data key="d1">concept</data>
      <data key="d2">Programming Process describes the stage of the project programming process, such as 'Uncoded: Pre-APP'.</data>
      <data key="d3">chunk-f1429fda71864e79d20fd0eb1fba290c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1773646038</data>
      <data key="d6" />
    </node>
    <node id="Status">
      <data key="d0">Status</data>
      <data key="d1">concept</data>
      <data key="d2">Status indicates the current status of the project, such as 'Closed'.</data>
      <data key="d3">chunk-f1429fda71864e79d20fd0eb1fba290c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1773646038</data>
      <data key="d6" />
    </node>
    <node id="Organisation Class">
      <data key="d0">Organisation Class</data>
      <data key="d1">concept</data>
      <data key="d2">Organisation Class is the classification of the organization involved in the project, including classes such as 'Individual'.</data>
      <data key="d3">chunk-f1429fda71864e79d20fd0eb1fba290c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1773646038</data>
      <data key="d6" />
    </node>
    <node id="Sector Name">
      <data key="d0">Sector Name</data>
      <data key="d1">concept</data>
      <data key="d2">Sector Name or Description identifies the sector, with examples including 'Multilateral trade negotiations', 'Sectors not specified', and 'Medical services'.&lt;SEP&gt;Sector Name represents the sector to which the project belongs, such as democratic participation or privatization.</data>
      <data key="d3">chunk-f1429fda71864e79d20fd0eb1fba290c&lt;SEP&gt;chunk-3a0a36834ad865ed58d796dd6028391f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1773646038</data>
      <data key="d6" />
    </node>
    <node id="Project Number">
      <data key="d0">Project Number</data>
      <data key="d1">data</data>
      <data key="d2">Project Number is a unique identifier for the project, such as 'M013170001'.&lt;SEP&gt;Project Number is the unique identifier for each project.</data>
      <data key="d3">chunk-f1429fda71864e79d20fd0eb1fba290c&lt;SEP&gt;chunk-3a0a36834ad865ed58d796dd6028391f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1773646038</data>
      <data key="d6" />
    </node>
    <node id="Climate Change Adaptation">
      <data key="d0">Climate Change Adaptation</data>
